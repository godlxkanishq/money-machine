# Frontend env. Copy to `.env` and restart `npm run dev`.
#
# Get a Client ID from Google Cloud Console:
#   APIs & Services → Credentials → Create credentials → OAuth client ID
#   Application type: Web application
#   Authorized JavaScript origins: http://localhost:5173  (+ your prod origin)
#
# Leave this UNSET to use the built-in demo sign-in (no Google account needed).
VITE_GOOGLE_CLIENT_ID=
