# Backend env. Must be the SAME Client ID as the frontend's VITE_GOOGLE_CLIENT_ID.
# Start the server with it set, e.g.:
#   GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com npm start
#
# When set, the server verifies real Google ID tokens and disables demo login.
# When unset, the server runs in DEMO mode.
GOOGLE_CLIENT_ID=
PORT=8787
